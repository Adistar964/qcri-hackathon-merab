# Copy this file to .env and fill in your real key. .env is gitignored.
FANAR_API_KEY=your_fanar_api_key_here

# Optional overrides (defaults shown)
FANAR_BASE_URL=https://api.fanar.qa/v1
FANAR_MODEL=Fanar
FANAR_VISION_MODEL=Fanar-Oryx-IVU-2
FANAR_STT_MODEL=Fanar-Aura-STT-LF-1
FANAR_TTS_MODEL=Fanar-Aura-TTS-2
FANAR_PLANNER_MODEL=Fanar

# Agent runtime
AGENT_WORKSPACE=agent_workspace
BROWSER_HEADLESS=false
BROWSER_LOCALE=en-US   # browser UI language (e.g. en-US or ar-QA); the agent handles either
BROWSER_FAST=false     # false = load the full site like a normal browser (recommended). true skips images/media for speed but can break pages.

# Anti-bot / reCAPTCHA (sign-in on portals like MOI E-Services / Tawtheeq)
BROWSER_PERSISTENT=true            # reuse a saved Chrome profile across runs so reCAPTCHA treats the browser as a returning, reputable user (big score boost)
BROWSER_PROFILE_DIR=               # optional: override where that profile lives (default: <AGENT_WORKSPACE>/chrome_profile)
# STRONGEST option for reCAPTCHA Enterprise (e.g. Tawtheeq) — drive YOUR OWN Chrome over CDP
# (real fingerprint + Google login). EASIEST: run start-chrome-debug.bat in the project root,
# sign into Google in the window it opens, then restart the backend — the agent AUTO-DETECTS that
# Chrome on port 9222 (no env var needed).
BROWSER_CDP_AUTODETECT=true         # set false to disable auto-using a debuggable Chrome on :9222
# BROWSER_CDP_URL=http://localhost:9222   # or point explicitly at a debuggable Chrome
# Tips for reCAPTCHA Enterprise (Tawtheeq): biggest lever is a RESIDENTIAL/Qatari IP (never a
# VPN/cloud); sign the fanar-chrome profile into a real Google account and use it a bit before the
# demo (cookies age = higher trust). OPTIONAL, strengthens the NON-CDP launch path against the
# CDP "Runtime.enable" leak:  pip install patchright  &&  patchright install chrome  (auto-used).
